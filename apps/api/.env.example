# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bonsai3d

# Redis connection string (used by BullMQ job queue)
REDIS_URL=redis://localhost:6379

# S3-compatible object storage (MinIO for local dev)
S3_BUCKET=bonsai3d
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Meshy API key for 3D reconstruction (https://www.meshy.ai)
MESHY_API_KEY=your-meshy-api-key-here

# JWT signing secret. Use "dev-secret-change-in-production" locally
# to enable the x-dev-user-id header bypass for easy testing.
JWT_SECRET=dev-secret-change-in-production

# Port for the API server
PORT=3001

# URL of the reconstruction microservice
RECON_SERVICE_URL=http://localhost:8000
