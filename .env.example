# ===========================================
# bonsai-3D — Root Environment Variables
# ===========================================
# Copy this file to .env and fill in values.
# App-specific env files live in apps/api/.env, apps/worker/.env, etc.

# --- Database (Postgres) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bonsai3d

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- MinIO / S3-compatible storage ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=bonsai3d
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Reconstruction service ---
RECON_SERVICE_URL=http://localhost:8000
